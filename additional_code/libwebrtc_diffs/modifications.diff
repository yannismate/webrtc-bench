+//
+// Created by yannis on 8/30/25.
+//
+
+#ifndef WEBRTC_CHECKOUT_STARLINK_RECONFIGURATION_GUARD_H
+#define WEBRTC_CHECKOUT_STARLINK_RECONFIGURATION_GUARD_H
+
+#include "api/units/timestamp.h"
+#include "api/units/time_delta.h"
+#include "api/units/data_rate.h"
+
+namespace webrtc {
+
+enum GuardState {
+  kNormal,
+  kDetectedFeedbackGap,
+  kConfirmedGap
+};
+
+struct StarlinkGuardConfig {
+  bool enabled = true;
+  TimeDelta feedback_gap_trigger = TimeDelta::Millis(72);   // treat >=72ms as candidate outage
+  TimeDelta gap_confirm_timer = TimeDelta::Millis(800);     // confirm gap with increased delay in feedback within the next 800ms
+  TimeDelta max_gap_pause = TimeDelta::Millis(800);         // max time to stay in confirmed gap state (ms)
