+//
+// Created by yannis on 7/5/25.
+//
+#ifndef MODULES_CONGESTION_CONTROLLER_GOOG_CC_RECONFIGURATION_DETECTOR_H_
+#define MODULES_CONGESTION_CONTROLLER_GOOG_CC_RECONFIGURATION_DETECTOR_H_
+
+#include <chrono>
+#include <array>
+#include <mutex>
+#include <optional>
+#include <thread>
+
+namespace webrtc {
+struct DetectionResult {
+  bool has_detected_period = false;
+  float period = 0;
+  bool was_adjusted = false;
+};
+
+struct ReconfigurationDetection {
+  float period = 0;
+  std::chrono::time_point<std::chrono::system_clock> expected_next_peak;
+};
+
+float get_recent_average(const std::vector<DetectionResult>& detections);
+
+class ReconfigurationDetector {
+public:
+  ReconfigurationDetector();
+  ~ReconfigurationDetector();
+  void update_delay_trend(float trend_value);
+  bool is_in_reconfiguration();
+private:
+  void update_detection_();
+private:
+  std::array<float, 9600> delay_trend_values_ = {};
+  unsigned int delay_trend_under_reconnect_threshold_ = 0;
+  bool collected_enough_data_ = false;
+  size_t delay_trend_latest_index_ = 0;
+  size_t ticks_ago_last_peak_detected_ = 9600;
+  std::vector<DetectionResult> past_detections_ = {};
+  std::thread processing_thread_;
+  std::mutex processing_mutex_;
+  bool stop_processing_thread_ = false;
+
+  std::mutex latest_detection_mutex_;
+  std::optional<ReconfigurationDetection> latest_detection_;
+
+  bool is_in_reconfiguration_state_ = false;
+  size_t reconfiguration_ticks_left_ = 0;
+};
+} // webrtc
+
+#endif // MODULES_CONGESTION_CONTROLLER_GOOG_CC_RECONFIGURATION_DETECTOR_H_
