diff --git a/modules/congestion_controller/goog_cc/reconfiguration_detector.cc b/modules/congestion_controller/goog_cc/reconfiguration_detector.cc
new file mode 100644
index 0000000000..a3a177c58c
--- /dev/null
+++ b/modules/congestion_controller/goog_cc/reconfiguration_detector.cc
@@ -0,0 +1,366 @@
+//
+// Created by yannis on 7/5/25.
+//
+
+#include <chrono>
+#include <iostream>
+#include <cmath>
+#include <vector>
+#include <algorithm>
+#include <unordered_map>
+
+#include "reconfiguration_detector.h"
+
+namespace webrtc {
+
+ReconfigurationDetector::ReconfigurationDetector() {
+  processing_thread_ = std::thread([this] {
+    while (!stop_processing_thread_) {
+      std::this_thread::sleep_for(std::chrono::seconds(5));
+      this->processing_mutex_.lock();
+      if (collected_enough_data_) {
+        update_detection_();
+      }
+      this->processing_mutex_.unlock();
+    }
+  });
+}
+
+ReconfigurationDetector::~ReconfigurationDetector() {
+  this->processing_mutex_.lock();
+  stop_processing_thread_ = true;
+  this->processing_mutex_.unlock();
+  if (processing_thread_.joinable()) {
+    processing_thread_.join();
+  }
+}
+
+void ReconfigurationDetector::update_delay_trend(float delay_trend) {
+  delay_trend_latest_index_++;
+  delay_trend_latest_index_ %= delay_trend_values_.size();
+  delay_trend_values_[delay_trend_latest_index_] = std::abs(delay_trend);
+  ticks_ago_last_peak_detected_++;
+  if (delay_trend < -0.02f) {
+    delay_trend_under_reconnect_threshold_++;
+  } else {
+    if (delay_trend >= 0.015f) {
+      ticks_ago_last_peak_detected_ = 0;
+    }
+    delay_trend_under_reconnect_threshold_ = 0;
+  }
+
+  // Collect at least a minute of data before predicting
+  if (!collected_enough_data_ && delay_trend_latest_index_ >= 40*60) {
+    this->processing_mutex_.lock();
+    collected_enough_data_ = true;
+    this->processing_mutex_.unlock();
+  }
+}
+
+void ReconfigurationDetector::update_detection_() {
+  std::cout << std::endl;
+  std::cout << "Running reconfiguration periodicy prediction." << std::endl;
+
+  if (past_detections_.size() > 20) {
+    past_detections_.erase(past_detections_.begin(), past_detections_.begin() + (past_detections_.size() - 20));
+  }
+
+  if (ticks_ago_last_peak_detected_ > 40*60*2) {
+    std::cout << "No peaks detected in the last 2 minutes, do not run detection algorithm." << std::endl;
+    DetectionResult result = { false, 0 };
+    past_detections_.emplace_back(result);
+    return;
+  }
+
+  const size_t buffer_size = delay_trend_values_.size();
+  const auto latest_index = delay_trend_latest_index_;
+  // Get a reference time here, since calculations will otherwise make it inaccurate
+  std::chrono::time_point<std::chrono::system_clock> next_peak_time = std::chrono::system_clock::now();
+
+  // Calculate mean directly from circular buffer
+  float sum = 0.0f;
+  for (size_t i = 0; i < buffer_size; ++i) {
+    sum += delay_trend_values_[i];
+  }
+  const float mean = sum / static_cast<float>(buffer_size);
+
+  // Calculate variance directly from circular buffer
+  float variance = 0.0f;
+  for (size_t i = 0; i < buffer_size; ++i) {
+    const float centered_value = delay_trend_values_[i] - mean;
+    variance += centered_value * centered_value;
+  }
+  variance /= static_cast<float>(buffer_size);
+
+  // Pre-calculate all correlations and store them for reuse
+  std::unordered_map<size_t, float> correlation_cache;
+
+  // Helper function to calculate correlation for a given lag
+  auto calculate_correlation = [&](size_t lag) -> float {
+    if (lag >= buffer_size) return 0.0f;
+
+    float correlation = 0.0f;
+    for (size_t i = 0; i < buffer_size - lag; ++i) {
+      // Read from circular buffer in chronological order
+      const size_t idx1 = (latest_index + 1 + i) % buffer_size;
+      const size_t idx2 = (latest_index + 1 + i + lag) % buffer_size;
+
+      const float val1 = delay_trend_values_[idx1] - mean;
+      const float val2 = delay_trend_values_[idx2] - mean;
+      correlation += val1 * val2;
+    }
+    return correlation / (static_cast<float>(buffer_size - lag) * variance);
+  };
+
+  // Helper function to get correlation (with caching)
+  auto get_correlation = [&](size_t lag) -> float {
+    auto it = correlation_cache.find(lag);
+    if (it != correlation_cache.end()) {
+      return it->second;
+    }
+    float correlation = calculate_correlation(lag);
+    correlation_cache[lag] = correlation;
+    return correlation;
+  };
+
+  // Store correlations for all lags
+  struct Peak {
+    int lag;
+    float correlation;
+  };
+  std::vector<Peak> peaks;
+
+  // Calculate autocorrelation for lags 400-3600 (10-90 seconds at 40Hz)
+  for (int lag = 400; lag <= 3600; ++lag) {
+    if (static_cast<size_t>(lag) >= buffer_size) break;
+
+    float correlation = get_correlation(static_cast<size_t>(lag));
+
+    // Keep significant correlations
+    if (correlation > 0.02f) {
+      peaks.push_back({lag, correlation});
+    }
+  }
+
+  if (peaks.empty()) {
+    std::cout << "  No significant periodic patterns found in 10-90 second range" << std::endl;
+    if (past_detections_.size() >= 3) {
+      std::vector recent_detections(past_detections_.end() - 3, past_detections_.end());
+      // if all negative, empty past detections
+      if (std::all_of(recent_detections.begin(), recent_detections.end(),
+                      [](const DetectionResult& res) { return !res.has_detected_period; })) {
+        past_detections_.clear();
+      }
+      else if (std::all_of(recent_detections.begin(), recent_detections.end(),
+                      [](const DetectionResult& res) { return res.has_detected_period; })) {
+        DetectionResult result = { false, 0 };
+        past_detections_.emplace_back(result);
+        auto const recent_average = get_recent_average(past_detections_);
+        std::cout << "Returning previous average: " << recent_average << "s" << std::endl;
+        latest_detection_mutex_.lock();
+        if (latest_detection_.has_value() && latest_detection_->expected_next_peak < next_peak_time) {
+          latest_detection_ = ReconfigurationDetection{
+            .period = recent_average,
+            .expected_next_peak = latest_detection_->expected_next_peak + std::chrono::milliseconds(static_cast<int>(recent_average * 1000))
+          };
+        }
+        latest_detection_mutex_.unlock();
+        return;
+      }
+    }
+
+    DetectionResult result = { false, 0 };
+    past_detections_.emplace_back(result);
+    return;
+  }
+
+  // Find strongest peak
+  const auto strongest = std::max_element(peaks.begin(), peaks.end(),
+    [](const Peak& a, const Peak& b) { return std::abs(a.correlation) < std::abs(b.correlation); });
+
+  const float strongest_period = static_cast<float>(strongest->lag) / 40.0f;
+
+  // Find harmonics of the strongest period
+  struct Harmonic {
+    float period;
+    float correlation;
+    float ratio;
+  };
+  std::vector<Harmonic> harmonics;
+
+  constexpr float harmonic_ratios[] = {0.125f, 0.25f, 0.5f, 2.0f, 3.0f};
+  for (const auto ratio : harmonic_ratios) {
+    const float harmonic_period = strongest_period * ratio;
+    if (harmonic_period >= 10.0f && harmonic_period <= 90.0f) {
+      const auto harmonic_lag = static_cast<size_t>(harmonic_period * 40.0f);
+      if (harmonic_lag < buffer_size) {
+        float correlation = get_correlation(harmonic_lag);
+        harmonics.push_back({harmonic_period, correlation, ratio});
+      }
+    }
+  }
+
+  // Select the best period: prefer smaller harmonics with correlation > 0.15
+  float best_period = strongest_period;
+  float best_correlation = strongest->correlation;
+
+  // Look for smaller harmonics with sufficient correlation (prefer the smallest one)
+  for (const auto& h : harmonics) {
+    if (h.ratio < 1.0f && std::abs(h.correlation) > 0.15f) {
+      if (h.period < best_period) {
+        best_period = h.period;
+        best_correlation = h.correlation;
+      }
+    }
+  }
+
+  // If no qualifying smaller harmonic found, pick the period with highest absolute correlation
+  if (best_period == strongest_period) {
+    for (const auto& h : harmonics) {
+      if (std::abs(h.correlation) > std::abs(best_correlation)) {
+        best_period = h.period;
+        best_correlation = h.correlation;
+      }
+    }
+  }
+
+  std::cout << "Detected periodicity: " << best_period << "s, correlation = " << best_correlation << std::endl;
+  auto const recent_avg = get_recent_average(past_detections_);
+  std::cout << "Recent average of past detections: " << recent_avg << "s" << std::endl;
+
+  // Check if recent average is close to 1/2, 1/3, 1/4 or 1/5 of the detected period, if you divide the detected period
+  constexpr float dividers[] = {1.0f, 2.0f, 3.0f, 4.0f, 5.0f};
+  bool new_detection_is_similar_to_previous = false;
+  float new_detection_divider = 0.0f;
+  if (recent_avg != 0.0f) {
+    for (const auto divider : dividers) {
+      if (std::abs(recent_avg - best_period / divider) < 1.0f) {
+        new_detection_is_similar_to_previous = true;
+        new_detection_divider = divider;
+        break;
+      }
+    }
+  }
+
+  if (!new_detection_is_similar_to_previous) {
+    std::cout << "New period not close to previous detections, adding and waiting for future similar detections." << std::endl;
+    DetectionResult result = { true, best_period };
+    past_detections_.emplace_back(result);
+    latest_detection_mutex_.lock();
+    latest_detection_ = std::nullopt;
+    latest_detection_mutex_.unlock();
+    return;
+  }
+
+  best_period = best_period / new_detection_divider;
+  std::cout << "New period is similar to previous detections, adjusting to " << best_period << "s." << std::endl;
+  DetectionResult result = { true, best_period, new_detection_divider != 1.0f };
+  past_detections_.emplace_back(result);
+
+  auto const returning_avg = get_recent_average(past_detections_);
+  std::cout << "Returning average: " << returning_avg << "s" << std::endl;
+
+  if (returning_avg == 0.0f) {
+    std::cout << "Returned average was 0, peak detection reset due to interval change." << std::endl;
+    latest_detection_mutex_.lock();
+    latest_detection_ = std::nullopt;
+    latest_detection_mutex_.unlock();
+    return;
+  }
+
+  auto interval_samples = static_cast<size_t>(std::round(returning_avg * 40.0f));
+  auto num_lookback = delay_trend_values_.size() / interval_samples;
+  double max_lookback_value = 0.0f;
+  auto max_lookback_sample_count = 0;
+  for (auto i = 0; i < interval_samples; i++) {
+    auto val = 0.0;
+    for (auto j = 0; j < num_lookback; j++) {
+      val += delay_trend_values_[(latest_index - i - (j * interval_samples) + delay_trend_values_.size()) % delay_trend_values_.size()];
+    }
+    if (val > max_lookback_value) {
+      max_lookback_value = val;
+      max_lookback_sample_count = i;
+    }
+  }
+
+  std::cout << "Max lookback value: " << max_lookback_value << " at sample count: " << max_lookback_sample_count << std::endl;
+  if (max_lookback_value < 0.04f) {
+    std::cout << "Detected interval peaks below threshold, not using detected interval." << std::endl;
+    latest_detection_mutex_.lock();
+    latest_detection_ = std::nullopt;
+    latest_detection_mutex_.unlock();
+    return;
+  }
+
+  auto expected_next_peak_index = (latest_index - max_lookback_sample_count + interval_samples) % delay_trend_values_.size();
+  std::cout << "Found last interval peak " << max_lookback_sample_count << " samples ago. Expecting next interval at sample " << expected_next_peak_index << std::endl;
+  next_peak_time = next_peak_time + std::chrono::seconds((interval_samples - max_lookback_sample_count) / 40);
+  std::cout << "Expecting next peak in " << (interval_samples - max_lookback_sample_count) *25 << "ms." << std::endl;
+
+  latest_detection_mutex_.lock();
+  latest_detection_ = ReconfigurationDetection{
+    .period = returning_avg,
+    .expected_next_peak = next_peak_time
+  };
+  latest_detection_mutex_.unlock();
+}
+
+bool ReconfigurationDetector::is_in_reconfiguration() {
+  if (is_in_reconfiguration_state_) {
+    if (reconfiguration_ticks_left_ == 0) {
+      std::cout << "Reconfiguration state ended." << std::endl;
+      is_in_reconfiguration_state_ = false;
+    } else if (delay_trend_values_[delay_trend_latest_index_] < 0.02f) {
+      reconfiguration_ticks_left_--;
+    } else if (delay_trend_under_reconnect_threshold_ >= 2) {
+      reconfiguration_ticks_left_ = 0;
+    }
+  } else {
+    // Switch to reconfiguration state if we have a detected peak coming up
+    latest_detection_mutex_.lock();
+    if (latest_detection_.has_value()) {
+      auto const& detection = latest_detection_.value();
+      auto now = std::chrono::system_clock::now();
+      // Peak within the next 300ms
+      if (detection.expected_next_peak <= now + std::chrono::milliseconds(300) && detection.expected_next_peak >= now - std::chrono::milliseconds(100)) {
+        is_in_reconfiguration_state_ = true;
+        reconfiguration_ticks_left_ = 40; // 1 second
+        std::cout << "Switching to reconfiguration state for " << reconfiguration_ticks_left_ << " ticks." << std::endl;
+      }
+    }
+    latest_detection_mutex_.unlock();
+  }
+
+  return is_in_reconfiguration_state_;
+}
+
+float get_recent_average(const std::vector<DetectionResult>& detections) {
+  // Iterate from the back of the vector and average over all recent detections until one is found that is not within a second of the others
+  if (detections.empty()) return 0.0f;
+  float sum = 0.0f;
+  size_t count = 0;
+  size_t was_adjusted_count = 0;
+
+  for (auto it = detections.rbegin(); it != detections.rend(); ++it) {
+    if (it->has_detected_period) {
+      if (it->period - sum / count > 1.0f && count > 0) {
+        break;
+      }
+      sum += it->period;
+      count++;
+      if (it->was_adjusted) {
+        was_adjusted_count++;
+        if (was_adjusted_count >= 5) {
+          // Last 3 detections were adjusted, reset detection
+          return 0.0f;
+        }
+      } else {
+        was_adjusted_count = 0; // Reset if we find a non-adjusted detection
+      }
+    }
+  }
+
+  return count > 0 ? sum / static_cast<float>(count) : 0.0f;
+}
+
+} // webrtc
