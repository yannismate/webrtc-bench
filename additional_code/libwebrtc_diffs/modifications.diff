+//
+// Created by yannis on 8/30/25.
+//
+
+#include "starlink_reconfiguration_guard.h"
+#include "api/safe_ostream.h"
+#include "api/units/timestamp.h"
+#include "api/units/time_delta.h"
+#include "api/units/data_rate.h"
+#include "rtc_base/logging.h"
+#include <iostream>
+
+namespace webrtc {
+void StarlinkReconfigurationGuard::OnFeedback(TimeDelta since_last_feedback, DataRate acked_bitrate, Timestamp now) {
+  // Detect a hole: a sudden feedback gap with near-zero delivery.
+  std::ostringstream stats_output;
+  stats_output << "SIGNAL/GUARD/" << since_last_feedback.ms() << ";";
+  if (cfg_.enabled) {
+    switch (state_) {
+      case GuardState::kNormal:
+        stats_output << "normal";
+        break;
+      case GuardState::kDetectedFeedbackGap:
+        stats_output << "detected_feedback_gap";
+        break;
+      case GuardState::kConfirmedGap:
+        stats_output << "confirmed_gap";
+        break;
+    }
+  } else {
+    stats_output << "disabled";
+  }
+
+  stats_output << std::endl;
+  webrtc::safe_cout() << stats_output.str();
+
+  if (!cfg_.enabled) {
+    return;
+  }
+
+  if (state_ == GuardState::kDetectedFeedbackGap && now >= awaiting_confirmation_until_) {
+    state_ = GuardState::kNormal;
+    webrtc::safe_cout() << "Starlink Reconfiguration Guard: Gap was not confirmed by increased delay in feedback.\n";
+    return;
+  }
+  if (state_ == GuardState::kConfirmedGap && now >= max_confirmed_state_until_) {
+    state_ = GuardState::kNormal;
+    webrtc::safe_cout() << "Starlink Reconfiguration Guard: Gap ended after max time. This should never happen!\n";
+    cooldown_until_ = Timestamp::MinusInfinity();
+    reprobe_next_interval_ = true;
+    return;
+  }
+  if (state_ != GuardState::kNormal) {
+    return;
+  }
+  if (since_last_feedback >= cfg_.feedback_gap_trigger) {
+    if (now < cooldown_until_) {
+      webrtc::safe_cout() << "Starlink Reconfiguration Guard: Ignoring hole since guard has engaged recently.\n";
+      return;
+    }
+    state_ = GuardState::kDetectedFeedbackGap;
+    awaiting_confirmation_until_ = now + cfg_.gap_confirm_timer;
+    std::stringstream out;
+    out << "Starlink Reconfiguration Guard detected feedback gap at " << now.ms() << " ms" << std::endl;
+    webrtc::safe_cout() << out.str();
+  }
+}
+
+void StarlinkReconfigurationGuard::UpdateCurrentFeedbackTime(Timestamp now) {
+  current_feedback_time_ = now;
+}
+
+bool StarlinkReconfigurationGuard::IgnoreSampleWithDelay(double recv_delta_ms, double send_delta_ms, int64_t arrival_time_ms) {
+  if (!cfg_.enabled) {
+    return false;
+  }
+  if (state_ == GuardState::kNormal) {
+    return false;
+  }
+  if (state_ == GuardState::kConfirmedGap) {
+    double delay_increase_ms = recv_delta_ms - send_delta_ms;
+    if (delay_increase_ms < 0) {
+      std::stringstream out;
+      out << "Starlink Reconfiguration Guard: Negative delay increase: " << delay_increase_ms << " ms\n";
+      webrtc::safe_cout() << out.str();
+      state_ = GuardState::kNormal;
+      cooldown_until_ = current_feedback_time_ + cfg_.min_gap_cooldown;
+      reprobe_next_interval_ = true;
+    }
+    return true;
+  }
+  if (state_ == GuardState::kDetectedFeedbackGap) {
+    double delay_increase_ms = recv_delta_ms - send_delta_ms;
+    if (delay_increase_ms >= cfg_.gap_delay_threshold) {
+      std::stringstream out;
+      out << "Starlink Reconfiguration Guard: Confirmed gap with delay increase of " << delay_increase_ms << " ms at " << current_feedback_time_.ms() << " ms\n";
+      webrtc::safe_cout() << out.str();
+      max_confirmed_state_until_ = current_feedback_time_ + cfg_.max_gap_pause;
+      state_ = GuardState::kConfirmedGap;
+    }
+  }
+  return state_ == GuardState::kConfirmedGap;
+}
+
+bool StarlinkReconfigurationGuard::JustFinishedReconfig() {
+  if (reprobe_next_interval_) {
+    reprobe_next_interval_ = false;
+    return true;
+  }
+  return false;
+}
+
+} // namespace webrtc
