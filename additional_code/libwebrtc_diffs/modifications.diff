       event_log_(event_log),
       config_(ProbeControllerConfig(key_value_config)) {
   Reset(Timestamp::Zero());
+  auto sl_probe_values = key_value_config->Lookup("StarlinkGuardProbingValues");
+  allow_further_probing_after_guard_engaged_ = key_value_config->IsEnabled("StarlinkGuardProbingAllowFurther");
+  if (!sl_probe_values.empty()) {
+    // Split by dash and parse to int, then devide by 100 to get a fraction.
+    starlink_guard_probing_values_.clear();
+    size_t start = 0;
+    while (start < sl_probe_values.length()) {
+      size_t end = sl_probe_values.find('-', start);
+      std::string token =
+          end == std::string::npos
+              ? sl_probe_values.substr(start)
+              : sl_probe_values.substr(start, end - start);
+      int value = std::stoi(token);
+      if (value > 0) {
+        starlink_guard_probing_values_.push_back(value / 100.0);
+      }
+      if (end == std::string::npos) {
+        break;
+      }
+      start = end + 1;
+    }
+  }
+  
+  std::ostringstream log_msg;
+  log_msg << "ProbeController: StarlinkGuardProbingValues: ";
+  for (double v : starlink_guard_probing_values_) {
+    log_msg << v << " ";
+  }
+  log_msg << "\n Allow further probing after guard engaged: " << allow_further_probing_after_guard_engaged_ << std::endl;
+  RTC_LOG(LS_WARNING) << log_msg.str();
