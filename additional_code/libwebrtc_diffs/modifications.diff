+  if (state_ == State::kWaitingForProbingResult)
+    return {};
+
+  DataRate clamped_estimate = std::min(current_estimate, target_rate * 1.5);
+  clamped_estimate = std::max(clamped_estimate, start_bitrate_);
+
+  std::vector<DataRate> targets;
+  for (double fraction : starlink_guard_probing_values_) {
+    targets.push_back(clamped_estimate * fraction);
+  }
+
+  if (targets.empty()) {
+    return {};
+  }
+
+  std::ostringstream log_msg;
+  std::ostringstream stat_msg;
+  stat_msg << "SIGNAL/PROBE/";
+  log_msg << "ProbeController: Start probing with targets: ";
+  auto first = true;
+  for (const auto& target : targets) {
+    log_msg << target.bps() << " bps, ";
+    if (!first) {
+      stat_msg << "-";
+    }
+    stat_msg << target.bps();
+    first = false;
+  }
+  log_msg << "at time: " << at_time.ms() << " ms" << std::endl;
+  stat_msg << std::endl;
+  webrtc::safe_cout() << log_msg.str();
+  webrtc::safe_cout() << stat_msg.str();
+
